SANGAM_DATABASE_PATH=/data/database/sangam.sqlite3
SANGAM_WORKSPACE_ROOT=/data/workspace
SANGAM_BACKUP_ROOT=/data/backups
SANGAM_MAX_PDF_BYTES=100000000
SANGAM_MAX_KARAKEEP_SOURCE_BYTES=5000000
SANGAM_BACKUP_RETENTION_COUNT=14
SANGAM_BACKUP_CHECK_INTERVAL_SECONDS=3600
SANGAM_BACKUPS_ENABLED=true
SANGAM_FRONTEND_DIST=/app/frontend/dist
SANGAM_API_URL=http://127.0.0.1:8000
SANGAM_AUTH_MODE=single_user
SANGAM_PUBLICATION_BASE_URL=http://127.0.0.1:8000/p
SANGAM_TRUSTED_PREVIEW_BASE_URL=http://127.0.0.1:8000/trusted-preview
SANGAM_PREVIEW_HMAC_SECRET=development-only-preview-secret-change-me
# Karakeep API root and a read-capable API key generated in Karakeep settings:
# SANGAM_KARAKEEP_BASE_URL=http://karakeep:3000/api/v1
# SANGAM_KARAKEEP_API_KEY=replace-with-karakeep-api-key
# SANGAM_KARAKEEP_TIMEOUT_SECONDS=20
# OpenRouter inference through the OpenAI Agents SDK and ChatKit:
# SANGAM_OPENROUTER_API_KEY=replace-with-openrouter-api-key
# SANGAM_CHAT_DEFAULT_MODEL=openai/gpt-5.4-mini
# SANGAM_CHAT_AVAILABLE_MODELS=["openai/gpt-5.4-mini","openai/gpt-5.4-nano","openai/gpt-5.6-terra"]
# Register the production application origin in ChatKit and replace local-dev:
# SANGAM_CHATKIT_DOMAIN_KEY=local-dev
# SANGAM_OPENROUTER_HTTP_REFERER=https://sangam.example.com
# SANGAM_OPENROUTER_APP_TITLE=Sangam
# Production Cloudflare Access settings:
# SANGAM_AUTH_MODE=cloudflare_access
# SANGAM_CLOUDFLARE_ACCESS_TEAM_DOMAIN=https://your-team.cloudflareaccess.com
# SANGAM_CLOUDFLARE_ACCESS_AUDIENCE=your-access-application-aud
# SANGAM_CLOUDFLARE_ACCESS_EMAIL=jay@example.com
# SANGAM_PUBLICATION_BASE_URL=https://docs.example.com/p
# SANGAM_TRUSTED_PREVIEW_BASE_URL=https://preview.example.com/trusted-preview
# SANGAM_TRUSTED_PREVIEW_HOST=preview.example.com
# SANGAM_TRUSTED_PREVIEW_PARENT_ORIGINS=["https://sangam.example.com"]
# SANGAM_TRUSTED_PREVIEW_CONNECT_SRC=[]
